# Cloudflare Pages Redirects
# Cloudflare handles .html extensions automatically. No manual rewrites needed for About/Contact.

# Clean up old paths if users bookmarked them
/legal/about.html    /about    301
/legal/contact.html  /contact  301
/legal/privacy.html  /privacy  301
/legal/terms.html    /terms    301

# Force canonical domain if you ever use a custom domain
# https://bloxstock.pages.dev/* https://www.bloxstock.com/:splat 301

# Fallback 404
/*    /404.html    404
